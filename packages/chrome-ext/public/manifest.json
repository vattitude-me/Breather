{
  "manifest_version": 3,
  "name": "Breather - Break Reminders",
  "version": "1.1.0",
  "description": "Gentle break reminders with a virtual plant companion. Take better breaks.",
  "permissions": ["alarms", "storage", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
